    `Urban (%)` = sprintf("%.2f (%.2f)", mean(urban_pop), sd(urban_pop)),
    `Alcohol` = sprintf("%.2f (%.2f)", mean(alcohol_per_cap), sd(alcohol_per_cap)),
    `Med. Income` = sprintf("%.0f (%.0f)", mean(median_income), sd(median_income)),
    N = n()
  ) %>%
  ungroup()
  
 # Make LATEX table so it looks pretty 
  
latex_table <- kable(comparison_data, 
                     format = "latex",          
                     booktabs = TRUE,           
                     escape = TRUE,           
                     align = c('l', rep('r', 7), 'r'), 
                     caption = "Pre-treatment Comparison: Colorado vs. All Other States (2006-2013)",
                     label = "pretreatment") %>% 
  kable_styling(latex_options = c("hold_position", "scale_down")) %>%
  add_footnote("Standard deviations in parentheses. N = number of state-year observations.",
