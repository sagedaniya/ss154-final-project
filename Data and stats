# MAKING VISUALIZATION OF TRAFFIC DEATH TRENDS

trend_data <- all_data %>% # Filter data to include years 2006-2023
  filter(year >= 2006 & year <= 2023) %>%
  # Create two groups: Colorado vs. all other 49 states
  mutate(Group = ifelse(state == "Colorado", "Colorado", "All Other States")) %>%
  # Group by year and group to calculate average fatality rate for each
  group_by(year, Group) %>%
  # Calculate mean fatality rate
  summarise(avg_fatality = mean(fatality_rate), .groups = 'drop')
  
  
  
# Create the line plot
trend_plot <- ggplot(trend_data, aes(x = year, y = avg_fatality, color = Group)) +
  geom_line(linewidth = 1) + 
  
  # 2014 to mark treatment year
  geom_vline(xintercept = 2014, linetype = "dashed", color = "gray50") +
  
  annotate("text", x = 2014, y = max(trend_data$avg_fatality), 
           label = "Treatment (2014)", vjust = -0.5, size = 3) +
  
  labs(
    x = "Year",
    y = "Traffic Fatality Rate (per 100M VMT)",
    title = "Traffic Fatality Trends: Colorado vs. All Other States",
    color = "" 
  ) +
  
  theme_minimal() +
  
  theme(
    legend.position = "bottom",           # Legend at bottom of plot
    panel.grid.minor = element_blank()  
  ) +
  
  # colors because why not
  scale_color_manual(values = c("Colorado" = "blue", "All Other States" = "red"))
