# Filtering years for pre-treatment 
pre_treatment <- all_data %>% 
     filter(year >= 2006 & year <= 2013)
 
# Calculate mean and standard deviation for each variable within each group
comparison_data <- pre_treatment %>%

 # Create a grouping variable
  mutate(Group = ifelse(state == "Colorado", "Colorado", "All Other States")) %>%
  # Group by this new variable so we get separate statistics for each group
  group_by(Group) %>%
  # Calculate  mean (SD) format for each variable
  summarise(
    `Fatality` = sprintf("%.2f (%.2f)", mean(fatality_rate), sd(fatality_rate)),
